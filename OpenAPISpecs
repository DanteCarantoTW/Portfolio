  "paths": {
    "/oauth2/token": {
      "post": {
        "summary": "Create Token",
        "description": "Create OAuth2.0 Bearer Token.",
        "tags": [
          "OAuth"
        ],
        "operationId": "getToken",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/auth"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "description": "JWT access token"
                    },
                    "expires_in": {
                      "type": "integer",
                      "description": "Token expiration time in seconds"
                    },
                    "token_type": {
                      "type": "string",
                      "description": "Type of the token (e.g., Bearer)"
                    },
                    "scope": {
                      "type": "string",
                      "description": "Authorized scopes"
                    }
                  }
                },
                "example": {
                  "access_token": "eyJhbGciOiJSUzI1NiIsImtpZCI6IjhERUYyQjVFNEJBQTJGQzlENDVFRUVBMDI0RjU5NzgzNUEzNDVCNEJSUzI1NiIsIng1dCI6ImplOHJYa3VxTDhuVVh1NmdKUFdYZzFvMFcwcyIsInR5cCI6ImF0K2p3dCJ9..lkRN80ouhdxa_fyyvf6N6Ya5RuJfYwCezqJJYCpR9dSQxdmLj6wSWUqxlIFmJbtqIW_R2cr8uwhJSYgwJ7-DHu9zgT0nRl90YNjLRlrGnA1qUJ5haCd6kLHZRvgpUqKFDr3ZB1CC-tTsFxJ9CFdacac798eK8lEabisUusHb6PLw4u2qahgkzk-5D3V-euJeRNvku_J7RQUDbnRAGbkDHV6xh0UN8DE-Gz1IqFDjvR5HJ6j4AgeIr2S1kYmXsn07LtiwsLuhRwi-1vNYfLgZiz430YD-ZS-cgB_TGwOxgSpuZ8ZPWtg2f6jCauvEKoI_lmob0fHuLobdEPlgvOux7g",
                  "expires_in": 3600,
                  "token_type": "Bearer",
                  "scope": "Gateway.ClaimsPay.PaymentMaster.Create"
                }
              }
            }
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/{ClientKey}/claimsPay/paymentMaster": {
      "post": {
        "summary": "Create Payment Master",
        "description": "The CreatePaymentMaster API is used for creating payments in ClaimsPay.",
        "tags": [
          "Payments"
        ],
        "operationId": "CreatePaymentMaster",
        "security": [
          {
            "bearer_auth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "PM_PaymentType",
                  "PM_PaymentID",
                  "PM_Amount",
                  "PM_CarrierId",
                  "PM_UserId",
                  "PM_User_FirstName",
                  "PM_User_LastName",
                  "PM_User_EmailAddress",
                  "PM_User_PhoneNumber",
                  "CL_ClaimNumber",
                  "PMA_MailTo",
                  "PMA_Street",
                  "PMA_City",
                  "PMA_State",
                  "PMA_Zipcode",
                  "PMA_Country",
                  "RMA_MailTo",
                  "RMA_Street",
                  "RMA_City",
                  "RMA_State",
                  "RMA_Zipcode",
                  "RMA_Country",
                  "PM_Additional_Text_16"
                ],
                "properties": {
                  "PM_PaymentType": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Determines the payment type of the request. This field is case sensitive, and values must be sent as defined - \"Contact(s)\", \"Vendor\", \"Lienholder\", \"Contact(s) and Vendor\", or \"Contact(s) and Mortgagee\".\n\n**Note:** \n- Only the valid values defined for this field will be accepted. \n- If this field is blank, the request will result in an error code that the field is Required.\n- If an invalid value is passed, the request will result in an error code that the PaymentType is not valid.",
                    "example": "Contact(s)"
                  },
                  "PM_PaymentID": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Unique identifier for this payment from the call originating system. This is the same as PM_CR_PaymentID that we return in the webhook, and is also the same as CRTrackingNumber in the payment feedback file.",
                    "example": "PMTID123456"
                  },
                  "PM_Amount": {
                    "type": "string",
                    "description": "Amount to pay contact or vendor. This must be a decimal with a maximum of 26 digits and 2 decimal places.\n",
                    "example": "17001.12"
                  },
                  "PM_CarrierId": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Pre-defined unique identifier for each of your carriers and sub-carriers. This is used for managing branding and account funding. Required for each payment request.\n",
                    "example": "World Insurance"
                  },
                  "PM_RequestReason": {
                    "type": "string",
                    "maxLength": 200,
                    "description": "Reason for making this payment. Required for \"Contacts and Mortgagee\" payment type.",
                    "example": "Loss Payment"
                  },
                  "PM_LoanAccountNumber": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Auto / Home Loan Account Number. Required for payment types - \"Lienholder\" and \"Contact(s) and Mortgagee\". The only special character that can be used currently is hyphen “-”.",
                    "example": "LN123456"
                  },
                  "PM_VIN": {
                    "type": "string",
                    "maxLength": 17,
                    "description": "Primary Manufacturer Vehicle Identification Number. Identifies the base VIN issued by the OEM before any dealer or region-specific modifications.\u003Cbr\u003EOptional for the Lienholder flow (to maintain backward compatibility with existing lienholder clients).\u003Cbr\u003E**Note:**This field supplements the Loan Account Number, which is a required field and is leveraged in lienholder payment workflows to enable matching of vehicle and loan account data.",
                    "example": "1HGCM82633A004352"
                  },
                  "PM_DisbursementLabel": {
                    "type": "string",
                    "maxLength": 50,
                    "pattern": "^[a-zA-Z0-9- ]$",
                    "description": "This field is only used for Non-Claim Disbursement payments. Required for these types. The text for the label of the first of the two-factor authentication values. Accepts upper case letters, lower case letters, numbers, spaces, and hyphens. Example - Account Number."
                  },
                  "PM_DisbursementValue": {
                    "type": "string",
                    "maxLength": 50,
                    "pattern": "^[a-zA-Z0-9- ]$",
                    "description": "This field is only used for Non-Claim Disbursement payments. Required for these types. The value is associated with the DisbursementLabel. Accepts upper case letters, lower case letters, numbers, spaces, and hyphens. Example: AN-12345."
                  },
                  "PM_Expedite": {
                    "type": "string",
                    "maxLength": 1,
                    "description": "Check payment will be delivered via UPS overnight mail (when applicable). \"Y\" or \"N\". If PM_Expedite is N or NULL, mail will be sent via USPS by default. Do not set PM_Expedite to Y if mailing to a P.O. Box."
                  },
                  "PM_Certified": {
                    "type": "string",
                    "maxLength": 1,
                    "description": "Check payment will be delivered via certified mail (when applicable). \"Y\" or \"N\"."
                  },
                  "PM_ENV": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Indicates the environment/system the payment was issued. Valid values are \"DEV\", \"QA\", or \"PROD\". This is used for tracking activity in the different environments/systems."
                  },
                  "PM_PrintNow": {
                    "type": "string",
                    "maxLength": 1,
                    "description": "Flag for a check to be printed locally. Default value = Null, which is treated as \"N\". \"Y\" or \"N\". PM_PrintNow functionality will only print images of the front page of the check."
                  },
                  "PM_Check_Fraud_Language": {
                    "type": "string",
                    "maxLength": 1400,
                    "description": "Allows English characters and specified Spanish characters. Fraud language displayed within the customer portal and on the check above the endorsement line. This field accepts 1400 characters in the API, but if printed on the back of a check, text longer than 830 characters is discarded. No encoded text allowed.\n"
                  },
                  "PM_DocCount": {
                    "type": "integer",
                    "maximum": 1,
                    "description": "Total number of documents expected to be attached to the payment. When there are no document attachments for the payment, do not send this field.\n"
                  },
                  "PM_Payments": {
                    "type": "object",
                    "description": "Lists a set of the payment's details in subsequent lines of the API request. Required for Vendor 1099.\n",
                    "properties": {
                      "PM_1099CostType1": {
                        "type": "string",
                        "maxLength": 9,
                        "description": "The type of 1099 reporting cost for the payment. Required for Vendor 1099.\nValid values are \"Indemnity\" or \"Expense\". Required when the PM_1099Reportable field is set to \"Y\".\n",
                        "example": "Indemnity"
                      },
                      "PM_1099CostType2": {
                        "type": "string",
                        "maxLength": 9,
                        "description": "The type of 1099 reporting cost for the payment. Not used in 1099 reports. Valid values are \"Indemnity\" or \"Expense\".\n",
                        "example": "Expense"
                      },
                      "PM_1099CostType3": {
                        "type": "string",
                        "maxLength": 9,
                        "description": "The type of 1099 reporting cost for the payment. Not used in 1099 reports. Valid values are \"Indemnity\" or \"Expense\".\n",
                        "example": "Indemnity"
                      },
                      "PM_1099CostType4": {
                        "type": "string",
                        "maxLength": 9,
                        "description": "The type of 1099 reporting cost for the payment. Not used in 1099 reports. Valid values are \"Indemnity\" or \"Expense\".\n",
                        "example": "Indemnity"
                      },
                      "PM_1099Amount1": {
                        "type": "string",
                        "description": "The amount of the payment associated with the reporting type specified in PM_1099CostType1. Required for Vendor 1099.\nRequired when the PM_1099CostType1 field is populated.\n",
                        "example": "227.37"
                      },
                      "PM_1099Amount2": {
                        "type": "string",
                        "description": "The amount of the payment associated with the reporting type specified in PM_1099CostType2.\nRequired when the PM_1099CostType2 field is populated. Not used in 1099 reports.\n",
                        "example": "510.75"
                      },
                      "PM_1099Amount3": {
                        "type": "string",
                        "description": "The amount of the payment associated with the reporting type specified in PM_1099CostType3.\nRequired when the PM_1099CostType3 field is populated. Not used in 1099 reports.\n",
                        "example": "510.75"
                      },
                      "PM_1099Amount4": {
                        "type": "string",
                        "description": "The amount of the payment associated with the reporting type specified in PM_1099CostType4.\nRequired when the PM_1099CostType4 field is populated. Not used in 1099 reports.\n",
                        "example": "5000.00"
                      },
                      "PM_1099Reportable": {
                        "type": "string",
                        "maxLength": 1,
                        "enum": [
                          "Y",
                          "N"
                        ],
                        "description": "Indicates the payment cost type for the payment is 1099 reportable. This is useful for payments to attorneys, where part of the payment can be used to pay a claim (Indemnity) and part of the payment is for the Attorney's fees (Expense).\nDefaults to \"N\". When PM_1099Reportable is \"Y\", the corresponding BUS_ReportingType1099, PM_1099CostType1, and PM_1099Amount1 fields must also contain the appropriate information for the payment.\n",
                        "example": "Y"
                      }
                    }
                  },
                  "PM_CaseID": {
                    "type": "string",
                    "maxLength": 36,
                    "description": "Hi Marley CaseID used for SMS communication. Requires ClaimsPay and Hi Marley integration.\n",
                    "example": "673febbb-9c05-4498-9d4d-61302eadc9a3"
                  },
                  "PM_UserId": {
                    "type": "string",
                    "maxLength": 60,
                    "description": "Unique username/id for the adjuster from the source system.\n",
                    "example": "user0123kjsd"
                  },
                  "PM_User_FirstName": {
                    "type": "string",
                    "maxLength": 30,
                    "description": "First name for the adjuster. This is displayed in the customer portal and in customer email. Valid RegEx: /^[ A-Za-z0-9-.' ]*$/\n",
                    "example": "John"
                  },
                  "PM_User_LastName": {
                    "type": "string",
                    "maxLength": 30,
                    "description": "Last name for the adjuster. This is displayed in the customer portal and in customer email. Valid RegEx: /^[ A-Za-z0-9-.' ]*$/\n",
                    "example": "Smith"
                  },
                  "PM_User_EmailAddress": {
                    "type": "string",
                    "maxLength": 254,
                    "description": "Email address for the adjuster from the claims management system. This is displayed in the customer portal and in customer email. Valid RegEx: /^[A-Z0-9._'%+-]+@(?:[A-Z0-9-]+.)+[A-Z]{2,}$/si\n",
                    "example": "johnsmith@bigcarrier.com"
                  },
                  "PM_User_PhoneNumber": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Phone number for the adjuster. This is displayed in the customer portal and in customer email. \nSupported formats include \"##########\", \"###-###-####\". \nCannot have parentheses \"(###)#######\", \"(###)-###-####\".\n",
                    "example": "6985231407"
                  },
                  "CL_ClaimNumber": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Claim number from the claim management system for this payment. This is displayed within the customer portal.\n",
                    "example": "256314-8"
                  },
                  "CL_CauseofLoss": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Cause of loss. Required for \"Contact(s) and Mortgagee\" payment type.\n",
                    "example": "Collision with motor vehicle"
                  },
                  "CL_DateofLoss": {
                    "type": "string",
                    "format": "date",
                    "description": "Date of loss. Required for \"Contact(s) and Mortgagee\" payment type. Format: YYYY-MM-DD.\n",
                    "example": "2022-10-15"
                  },
                  "CL_PolicyNumber": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Policy number. Required for “Contact(s) and Mortgagee” payment type.\n",
                    "example": "INJ456"
                  },
                  "CL_ClaimType": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Type of claim, typically the line of business. This field can be leveraged to disable payment methods.\n",
                    "example": "Personal Auto"
                  },
                  "CL_CoverageType": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Type of coverage. This is displayed within the customer portal.\n",
                    "example": "Collision"
                  },
                  "CL_ClaimUnitNumber": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Claim unit number or reserve from the claim management system to which this payment is related.\n",
                    "example": "1234567"
                  },
                  "PML_State": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "The state where the claim was filed. This field can be used in conjunction with CL_ClaimType to disable payment methods by line of business.\n Two (2) for US, One Hundred (100) for International",
                    "example": "CA"
                  },
                  "PCON_ContactId": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Unique identifier for this contact from the call originating system. Required for payment types: \n- Contact(s)\n- Contact(s) and Vendor\n- Contact(s) and Mortgagee.\nThe payment token One Inc returns is tied directly to the ContactId that is sent in the CreatePaymentMaster.\n",
                    "example": "con147"
                  },
                  "PCON_FirstName": {
                    "type": "string",
                    "maxLength": 100,
                    "pattern": "^[ A-Za-z0-9-.' ]*$",
                    "description": "First Name of Primary Contact. Required for payment types:\n- Contact(s)\n- Contact(s) and Vendor\n- Contact(s) and Mortgagee.\n",
                    "example": "Jane"
                  },
                  "PCON_LastName": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Last Name of Primary Contact. Required for payment types:\n- Contact(s)\n- Contact(s) and Vendor\n- Contact(s) and Mortgagee.\nIf the contact is a business (PCONBusiness = Y) then allowed characters are: /^[a-zA-Z0-9 !@#?();:=,\\{}[]'+^$_-.&/]$/\n",
                    "example": "Smith"
                  },
                  "PCON_MobilePhone": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "This is the best contact number for the primary contact. Required for payment types:\n- Contact(s)\n- Contact(s) and Vendor\n- Contact(s) and Mortgagee.\nSupported formats include \"##########\", \"###-###-####\". \nCannot have parentheses \"(###)#######\", \"(###)-###-####\".\n",
                    "example": "6985231407"
                  },
                  "PCON_EmailAddress": {
                    "type": "string",
                    "maxLength": 254,
                    "pattern": "^[A-Z0-9._'%+-]+@(?:[A-Z0-9-]+\\.)+[A-Z]{2,}$",
                    "description": "Email address of primary contact. Required for payment types:\n- Contact(s)\n- Contact(s) and Vendor\n- Contact(s) and Mortgagee.\n Valid RegEx: ^[A-Z0-9._'%+-]+@(?:[A-Z0-9-]+\\.)+[A-Z]{2,}$.\n",
                    "example": "jsmith@emailprovider.com"
                  },
                  "PCON_Approval_Reqd": {
                    "type": "string",
                    "maxLength": 1,
                    "description": "This flag indicates that approval is required from this contact before paying a vendor. \nRequired for payment types: Contact(s) and Vendor.\n",
                    "example": "Y"
                  },
                  "PCON_Business": {
                    "type": "string",
                    "maxLength": 1,
                    "description": "A flag to indicate if the payee is a business. \n\"Y\" = Payee is a company \n\"N\" = Payee is an individual. \nWhen this field is set to \"Y\", PCON_FirstName is not required.\n",
                    "example": "Y"
                  },
                  "PCON_OfficePhone": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Office Phone Number of Primary Contact. \nSupported formats include \"##########\", \"###-###-####\". \nCannot have parentheses \"(###)#######\", \"(###)-###-####\".\n",
                    "example": "6985231407"
                  },
                  "PCON_Delivery": {
                    "type": "string",
                    "maxLength": 20,
                    "description": "Specifies the communication method for the primary contact. \nIf this parameter is not supplied, default communication method(s) will be used.\n",
                    "example": "Email"
                  },
                  "PCON_SSN": {
                    "type": "string",
                    "maxLength": 11,
                    "description": "Social Security Number of Primary Contact.\n",
                    "example": "999-99-9999"
                  },
                  "PCON_DOB": {
                    "type": "string",
                    "format": "date",
                    "description": "Date of Birth of Primary Contact. Format: YYYY-MM-DD.\n",
                    "example": "1980-11-07"
                  },
                  "SCON_ContactId": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Unique identifier for this contact from the call originating system. \nRequired only if a secondary contact is needed.\n**Note:** The payment token One Inc returns is tied directly to the ContactId that is sent in the CreatePaymentMaster.\n",
                    "example": "con147"
                  },
                  "SCON_FirstName": {
                    "type": "string",
                    "maxLength": 100,
                    "pattern": "^[ A-Za-z0-9-.' ]*$",
                    "description": "First name of secondary contact. Required only if a secondary contact is needed.\n",
                    "example": "Joe"
                  },
                  "SCON_LastName": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Last name of secondary contact. Required only if a secondary contact is needed.\nIf the contact is a business (PCONBusiness = Y) then allowed characters are: /^[a-zA-Z0-9 !@#?();:\u003E=\u003C,{}[]'+*^$_-.&/\\\\]$/.\n",
                    "example": "Bloggs"
                  },
                  "SCON_MobilePhone": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Mobile phone number of secondary contact. Required only if a secondary contact is needed.\nSupported formats include \"##########\", \"###-###-####\". \nCannot have parentheses \"(###)#######\", \"(###)-###-####\".\n",
                    "example": "6985231407"
                  },
                  "SCON_EmailAddress": {
                    "type": "string",
                    "maxLength": 254,
                    "pattern": "^[A-Z0-9._'%+-]+@(?:[A-Z0-9-]+\\.)+[A-Z]{2,}$",
                    "description": "Email address of secondary contact. Required only if a secondary contact is needed.\n Valid RegEx: ^[A-Z0-9._'%+-]+@(?:[A-Z0-9-]+\\.)+[A-Z]{2,}$",
                    "example": "jsmith@emailprovider.com"
                  },
                  "SCON_Approval_Reqd": {
                    "type": "string",
                    "maxLength": 1,
                    "description": "Required only if a secondary contact is needed and issuing a ‘Contact(s) and Vendor’ payment type.\n",
                    "example": "Y"
                  },
                  "SCON_Business": {
                    "type": "string",
                    "maxLength": 1,
                    "description": "Indicates the payment is for an insured/claimant that is a business. \n\"Y\" = Payee is a company \n\"N\" = Payee is an individual. \nWhen this field is set to \"Y\": \n- SCON_FirstName is not required \n- The payment method will always be selected by the primary contact.\n",
                    "example": "Y"
                  },
                  "SCON_OfficePhone": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Office phone number of secondary contact. \nSupported formats include \"##########\", \"###-###-####\". \nCannot have parentheses \"(###)#######\", \"(###)-###-####\".\n",
                    "example": "6985231407"
                  },
                  "SCON_Delivery": {
                    "type": "string",
                    "maxLength": 20,
                    "description": "Specifies the communication method for the secondary contact. \nIf this parameter is not supplied, default communication method(s) will be used.\n",
                    "example": "Email"
                  },
                  "SCON_SSN": {
                    "type": "string",
                    "maxLength": 11,
                    "description": "Social security number of secondary contact.\n",
                    "example": "999-99-9999"
                  },
                  "SCON_DOB": {
                    "type": "string",
                    "format": "date",
                    "description": "Date of birth of secondary contact. Format: YYYY-MM-DD.\n",
                    "example": "1913-11-07"
                  },
                  "BUS_TIN": {
                    "type": "string",
                    "maxLength": 11,
                    "description": "Tax identification number of business. \nRequired for Vendor, Contact(s) & Vendor. \nWhen TIN is not specified, the payment method is based on the vendor subtype and will be mailed check or mailed virtual card. \n**Note**: This is not required for \"Contact(s) and Mortgagee\" or \"Lienholder\" payments.\n",
                    "example": "12-3456789"
                  },
                  "BUS_BusinessId": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "The unique identifier for this vendor from the system that originated the call. \nRequired for Vendor, Contact(s) & Vendor, Contact(s) & Mortgagee, Lienholder.\n Optional for clients using the latest code version, but required for the legacy API.",
                    "example": "123456789"
                  },
                  "BUS_Name": {
                    "type": "string",
                    "maxLength": 180,
                    "pattern": "^[a-zA-Z0-9 !@#?();:\u003E=\u003C,{}[]'+*^$_-.&/\\]$",
                    "description": "The name of the vendor. \nRequired for Vendor, Contact(s) & Vendor, Contact(s) & Mortgagee, Lienholder.\n",
                    "example": "World Body Shop"
                  },
                  "BUS_Type": {
                    "type": "string",
                    "maxLength": 20,
                    "description": "The type of business operated by the vendor. \nRequired for Vendor, Contact(s) & Vendor, Contact(s) & Mortgagee, Lienholder.\n",
                    "example": "Vendor"
                  },
                  "BUS_SubType": {
                    "type": "string",
                    "maxLength": 225,
                    "description": "Sub-type of the vendor's business. \nRequired for Vendor, Contact(s) & Vendor.\n",
                    "example": "Auto Repair Shop"
                  },
                  "BUS_EmailAddress": {
                    "type": "string",
                    "maxLength": 254,
                    "pattern": "^[A-Z0-9._'%+-]+@(?:[A-Z0-9-]+\\.)+[A-Z]{2,}$",
                    "description": "Email address of business.\n",
                    "example": "WorldShop@emailprovider.com"
                  },
                  "BUS_Street": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Street address of business. \nRequired for Vendor, Contact(s) & Vendor, Contact(s) & Mortgagee, Lienholder.\n No quotation marks (\"\"), ampersands (&), or chevrons (\u003C \u003E).",
                    "example": "123 East Street, Ste. #5"
                  },
                  "BUS_City": {
                    "type": "string",
                    "maxLength": 100,
